{
  "name": "permissiongranted.app",
  "version": "0.1.0",
  "description": "A playful, email-first permission request service built on Cloudflare Workers.",
  "private": true,
  "license": "MIT",
  "homepage": "https://permissiongranted.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Outdoor-Technica/permissiongranted.app.git"
  },
  "bugs": {
    "url": "https://github.com/Outdoor-Technica/permissiongranted.app/issues"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "check": "npm run cf-typegen && npm run typecheck && npm test && npm run build && wrangler deploy --dry-run",
    "db:local": "wrangler d1 migrations apply permission-granted --local",
    "db:remote": "wrangler d1 migrations apply permission-granted --remote",
    "deploy": "npm run build && wrangler deploy",
    "dev": "npm run build && wrangler dev --live-reload",
    "preview": "vite preview",
    "setup": "node scripts/setup-local.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.client.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.tools.json"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.6",
    "@fontsource/ibm-plex-mono": "^5.2.6",
    "@fontsource/ibm-plex-sans": "^5.2.6",
    "hono": "^4.9.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.27.0"
  },
  "engines": {
    "node": ">=22"
  }
}
